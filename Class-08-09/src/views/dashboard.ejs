<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>B&W Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
  </head>
  <body class="bg-gray-50 text-black font-sans">
    <div class="flex h-screen">
      <aside class="w-64 bg-black text-white flex flex-col">
        <div class="p-6 text-2xl font-bold border-b border-gray-800">
          IMS Pro
        </div>
        <nav class="flex-1 p-4 space-y-2">
          <a href="#" class="block py-2.5 px-4 rounded bg-white text-black"
            >Dashboard</a
          >
          <a
            href="#"
            class="block py-2.5 px-4 rounded hover:bg-gray-800 transition"
            >Inventory</a
          >
          <a
            href="#"
            class="block py-2.5 px-4 rounded hover:bg-gray-800 transition"
            >Settings</a
          >
        </nav>
        <div class="p-4 border-t border-gray-800 text-sm text-gray-400">
          v1.0.2
        </div>
      </aside>

      <main class="flex-1 flex flex-col overflow-hidden">
        <header
          class="flex items-center justify-between p-6 bg-white border-b border-gray-200"
        >
          <h1 class="text-xl font-semibold">Inventory Overview</h1>
          <div class="flex items-center space-y-4">
            <span class="text-sm font-medium mr-4">Admin User</span>
            <div class="w-10 h-10 bg-black rounded-full"></div>
          </div>
        </header>

        <div class="p-8 overflow-y-auto">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <div class="p-6 bg-white border border-black rounded-lg shadow-sm">
              <p
                class="text-sm text-gray-500 uppercase font-bold tracking-wider"
              >
                Total Products
              </p>
              <p class="text-3xl font-black mt-1">
                <%= products.length %>
              </p>
            </div>
            <div class="p-6 bg-white border border-black rounded-lg shadow-sm">
              <p
                class="text-sm text-gray-500 uppercase font-bold tracking-wider"
              >
                Low Stock
              </p>
              <p class="text-3xl font-black mt-1 text-red-600">03</p>
            </div>
            <div class="p-6 bg-black text-white rounded-lg shadow-sm">
              <p
                class="text-sm text-gray-400 uppercase font-bold tracking-wider"
              >
                Total Valuation
              </p>
              <p class="text-3xl font-black mt-1">Rs 1.2M</p>
            </div>
          </div>

          <div
            class="bg-white border border-gray-200 rounded-lg overflow-hidden"
          >
            <table class="w-full text-left">
              <thead class="bg-gray-100 border-b border-gray-200">
                <tr>
                  <th
                    class="px-6 py-4 text-xs font-bold uppercase text-gray-600"
                  >
                    Product
                  </th>
                  <th
                    class="px-6 py-4 text-xs font-bold uppercase text-gray-600"
                  >
                    Price
                  </th>
                  <th
                    class="px-6 py-4 text-xs font-bold uppercase text-gray-600"
                  >
                    Stock
                  </th>
                  <th
                    class="px-6 py-4 text-xs font-bold uppercase text-gray-600"
                  >
                    Action
                  </th>
                </tr>
              </thead>
              <!-- {
        id: 1,
        name: "MacBook Pro M3",
        category: "Electronics",
        price: 450000,
        stock: 12,
        status: "In Stock"
    }, -->
              <tbody class="divide-y divide-gray-200">
    <% products.map(({id, name, category, stock, price, status}) => { %>
    <tr class="hover:bg-gray-50 transition">
        <td class="px-6 py-4 font-medium italic"><%= name %></td>
        <td class="px-6 py-4">Rs <%= price.toLocaleString() %></td>
        
        <td class="px-6 py-4 <%= stock <= 0 ? 'text-red-500 font-bold' : 'text-gray-700' %>">
            <%= stock <= 0 ? "Out of Stock" : stock %>
        </td>
        
        <td class="px-6 py-4 text-blue-600 underline cursor-pointer">
            Edit
        </td>
    </tr>
    <% }) %> </tbody>
            </table>
          </div>
        </div>
      </main>
    </div>
  </body>
</html>
